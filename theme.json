{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "customTemplates": [
    {
      "name": "page-canvas",
      "title": "Canvas",
      "postTypes": ["page"]
    }
  ],
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "900px",
      "wideSize": "1140px"
    },
    "color": {
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        { "slug": "base", "color": "#ffffff", "name": "Base" },
        { "slug": "contrast", "color": "#111111", "name": "Contrast" },
        { "slug": "contrast-2", "color": "#333333", "name": "Body" },
        { "slug": "contrast-3", "color": "#666666", "name": "Muted" },
        {
          "slug": "subtle-background",
          "color": "#f8f8f8",
          "name": "Subtle Background"
        },
        { "slug": "border", "color": "#eeeeee", "name": "Border" }
      ]
    },
    "typography": {
      "fluid": true,
      "customFontSize": true,
      "dropCap": false,
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "lineHeight": true,
      "textDecoration": true,
      "textTransform": true,
      "fontFamilies": [
        {
          "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
          "name": "System",
          "slug": "system"
        },
        {
          "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
          "name": "System Mono",
          "slug": "system-mono"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.125rem"
        },
        {
          "slug": "x-large",
          "name": "X-Large",
          "size": "1.5rem",
          "fluid": {
            "min": "1.25rem",
            "max": "1.5rem"
          }
        },
        {
          "slug": "xx-large",
          "name": "XX-Large",
          "size": "2.25rem",
          "fluid": {
            "min": "1.75rem",
            "max": "2.25rem"
          }
        },
        {
          "slug": "huge",
          "name": "Huge",
          "size": "3rem",
          "fluid": {
            "min": "2.25rem",
            "max": "3rem"
          }
        }
      ]
    },
    "spacing": {
      "customSpacingSize": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingSizes": [
        { "slug": "20", "size": "0.5rem", "name": "X-Small" },
        { "slug": "30", "size": "1rem", "name": "Small" },
        { "slug": "40", "size": "1.5rem", "name": "Medium" },
        { "slug": "50", "size": "2rem", "name": "Large" },
        { "slug": "60", "size": "3rem", "name": "X-Large" },
        { "slug": "70", "size": "4rem", "name": "2X-Large" },
        { "slug": "80", "size": "5rem", "name": "3X-Large" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast-2)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        },
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.15",
          "letterSpacing": "-0.02em"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--huge)"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--contrast-3)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--contrast)",
          "text": "var(--wp--preset--color--base)"
        },
        "typography": {
          "fontWeight": "600"
        },
        "border": {
          "radius": "4px"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1.5rem",
            "bottom": "0.75rem",
            "left": "1.5rem"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--contrast-2)"
          }
        }
      }
    },
    "blocks": {
      "core/code": {
        "color": {
          "background": "var(--wp--preset--color--subtle-background)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--system-mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        },
        "border": {
          "radius": "4px",
          "color": "var(--wp--preset--color--border)",
          "style": "solid",
          "width": "1px"
        },
        "spacing": {
          "padding": {
            "top": "1.25rem",
            "right": "1.25rem",
            "bottom": "1.25rem",
            "left": "1.25rem"
          }
        }
      },
      "core/separator": {
        "color": {
          "background": "var(--wp--preset--color--border)"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
